{
  "version": 1,
  "service": "asaphone-provision",
  "discovery_url": "https://asaph-d.github.io/Portfolio/provision/bootstrap.json",
  "api_lan": "https://pbx.local/provision",
  "api_remote": "https://advance-associates-brakes-reducing.trycloudflare.com/provision",
  "pbx_host": "pbx.local",
  "pbx_lan_ip": "192.168.1.80",
  "sip_server": "192.168.1.80",
  "api_lan_ip": "https://192.168.1.80/provision",
  "wss_port": 8089,
  "wss_url": "wss://192.168.1.80:8089/ws",
  "wss_url_lan": "wss://192.168.1.80:8089/ws",
  "video_codecs": [
    "vp8",
    "h264"
  ],
  "ice_servers": [
    {
      "urls": [
        "stun:192.168.1.80:3478"
      ]
    }
  ],
  "vpn": {
    "enable": true,
    "wireguard_remote_available": false,
    "endpoint_remote": "",
    "endpoint_lan": "192.168.1.80:51820",
    "allowed_ips": "192.168.1.0/24,10.10.10.0/24,10.200.0.0/24"
  },
  "remote_access": {
    "mode": "tailscale",
    "tailscale": {
      "subnet_routes": [
        "192.168.1.0/24",
        "10.10.10.0/24"
      ],
      "install": "https://tailscale.com/download",
      "hint": "Même compte Tailscale que le PBX ; activer les routes subnet sur le téléphone"
    }
  },
  "endpoints": {
    "register": "/api/v1/register.php",
    "verify": "/api/v1/verify.php",
    "claim": "/api/v1/claim.php",
    "reconnect": "/api/v1/reconnect.php",
    "session": "/api/v1/session.php",
    "vpn_register": "/api/v1/vpn/register.php",
    "vpn_verify": "/api/v1/vpn/verify.php",
    "vpn_claim": "/api/v1/vpn/claim.php",
    "vpn_enroll": "/api/v1/vpn/enroll.php",
    "vpn_revoke": "/api/v1/vpn/revoke.php",
    "vpn_status": "/api/v1/vpn/status.php"
  },
  "deeplink_scheme": "asaphone",
  "notes": "4G/Starlink : Tailscale (pas WireGuard UDP). Wi-Fi site : WireGuard endpoint_lan ou LAN direct."
}
